{
  "manifest_version": 3,
  "name": "Recall",
  "version": "1.0.0",
  "description": "Things you want your future self to revisit.",

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16":  "icon.png",
      "48":  "icon.png",
      "128": "icon.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  }
}